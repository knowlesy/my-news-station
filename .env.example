# ═══════════════════════════════════════════════════════════════════
# Environment variable template — copy to .env and fill in your values
# Never commit .env to version control!
# ═══════════════════════════════════════════════════════════════════

# ── LLM Backend ─────────────────────────────────────────────────────
# Choose: gemini | claude_api | claude_cli
LLM_BACKEND=claude_cli

# ── Google Gemini (LLM_BACKEND=gemini) ──────────────────────────────
# Free key: https://aistudio.google.com/app/apikey
GOOGLE_AI_KEY=

# ── Anthropic Claude API (LLM_BACKEND=claude_api) ───────────────────
# Key: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ── Claude / Gemini model names ──────────────────────────────────────
CLAUDE_MODEL=claude-opus-4-5
GEMINI_MODEL=gemini-1.5-pro

# ── Server paths ─────────────────────────────────────────────────────
DATA_DIR=/app/data
FRONTEND_DIR=/app/frontend
BIND_ADDR=0.0.0.0:3000

# ── Browser / display ────────────────────────────────────────────────
DISPLAY=:99

# ── Optional: override cookie path ───────────────────────────────────
# COOKIES_PATH=/app/cookies.json
